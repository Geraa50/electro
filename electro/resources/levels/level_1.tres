[gd_resource type="Resource" script_class="LevelData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/level/level_data.gd" id="1"]

[resource]
script = ExtResource("1")
level_name = "Уровень 1: Последовательное соединение"
level_description = "Соберите цепь с последовательным соединением резисторов, чтобы лампа получила нужное напряжение."
hint_text = "При последовательном соединении общее сопротивление равно сумме: R = R1 + R2 + R3. Используйте закон Ома: I = V / R, чтобы подобрать нужные резисторы. Лампе нужно 6В."
fixed_components = [{
"type": "power_source",
"position": "Vector2(128, 128)",
"params": {
"voltage": 12.0,
"max_current": 2.0
}
}, {
"type": "consumer",
"position": "Vector2(576, 384)",
"params": {
"required_voltage": 6.0,
"required_power": 3.0,
"name": "Лампа",
"resistance": 20.0
}
}]
available_components = [{
"type": "wire",
"params": {}
}, {
"type": "wire",
"params": {}
}, {
"type": "wire",
"params": {}
}, {
"type": "wire",
"params": {}
}, {
"type": "resistor",
"params": {
"resistance": 10.0
}
}, {
"type": "resistor",
"params": {
"resistance": 10.0
}
}, {
"type": "resistor",
"params": {
"resistance": 5.0
}
}]
win_condition = {
"type": "voltage",
"target_value": 6.0,
"tolerance": 1.0
}
show_schematic = true
allow_parameter_editing = false
time_limit = 0.0
max_attempts = 0
