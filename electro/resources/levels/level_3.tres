[gd_resource type="Resource" script_class="LevelData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/level/level_data.gd" id="1"]

[resource]
script = ExtResource("1")
level_name = "Уровень 3: Настройка параметров"
level_description = "Настройте параметры источника питания и резисторов, чтобы получить нужное напряжение на потребителе."
hint_text = "Используйте вольт-ампер метр для измерения. Меняйте параметры компонентов (ПКМ или двойной клик). Цель: лампа должна получить ровно 5В."
fixed_components = [{
"type": "power_source",
"position": "Vector2(128, 128)",
"params": {
"voltage": 10.0,
"max_current": 3.0
}
}, {
"type": "consumer",
"position": "Vector2(576, 384)",
"params": {
"required_voltage": 5.0,
"required_power": 2.5,
"name": "Лампа",
"resistance": 10.0
}
}]
available_components = [{
"type": "wire",
"params": {}
}, {
"type": "wire",
"params": {}
}, {
"type": "wire",
"params": {}
}, {
"type": "resistor",
"params": {
"resistance": 10.0
}
}, {
"type": "voltammeter",
"params": {}
}]
win_condition = {
"type": "voltage",
"target_value": 5.0,
"tolerance": 0.5
}
show_schematic = true
allow_parameter_editing = true
time_limit = 0.0
max_attempts = 0
